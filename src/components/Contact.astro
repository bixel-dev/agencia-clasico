---
---
<section id="contacto" class="bg-brand-light py-32 md:py-40">
  <div class="max-w-6xl mx-auto px-8 md:px-14">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24">

      <!-- Info -->
      <div class="contact-info">
        <p class="label-tag mb-5">Contacto</p>
        <h2 class="font-heading text-brand-dark font-light leading-tight mb-12"
            style="font-size: clamp(1.8rem, 3.5vw, 3rem);">
          Hablemos de tu próximo proyecto.
        </h2>

        <div class="space-y-8">
          <div>
            <p class="label-tag mb-1.5">Email</p>
            <a href="mailto:hola@clasi.co"
               class="font-sans text-brand-dark text-sm hover:text-brand-muted transition-colors duration-300">
              hola@clasi.co
            </a>
          </div>
          <div>
            <p class="label-tag mb-1.5">Teléfono</p>
            <a href="tel:+56912345678"
               class="font-sans text-brand-dark text-sm hover:text-brand-muted transition-colors duration-300">
              +56 9 1234 5678
            </a>
          </div>
          <div>
            <p class="label-tag mb-1.5">Ubicación</p>
            <p class="font-sans text-brand-dark text-sm">Santiago, Chile</p>
          </div>
        </div>
      </div>

      <!-- Form -->
      <form id="contact-form" class="contact-form space-y-8">
        <div>
          <label class="label-tag block mb-2">Nombre</label>
          <input
            type="text" name="name" required
            placeholder="Tu nombre"
            class="w-full border-b border-brand-dark/20 bg-transparent pb-3 text-brand-dark text-sm font-sans
                   focus:outline-none focus:border-brand-dark transition-colors duration-300 placeholder:text-brand-muted/40"
          />
        </div>
        <div>
          <label class="label-tag block mb-2">Email</label>
          <input
            type="email" name="email" required
            placeholder="tu@email.com"
            class="w-full border-b border-brand-dark/20 bg-transparent pb-3 text-brand-dark text-sm font-sans
                   focus:outline-none focus:border-brand-dark transition-colors duration-300 placeholder:text-brand-muted/40"
          />
        </div>
        <div>
          <label class="label-tag block mb-2">Mensaje</label>
          <textarea
            name="message" rows="4" required
            placeholder="Cuéntanos sobre tu proyecto..."
            class="w-full border-b border-brand-dark/20 bg-transparent pb-3 text-brand-dark text-sm font-sans
                   focus:outline-none focus:border-brand-dark transition-colors duration-300 placeholder:text-brand-muted/40 resize-none"
          ></textarea>
        </div>
        <button type="submit" class="btn-dark mt-2">Enviar mensaje</button>
      </form>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.contact-info > *', {
    y: 20, opacity: 0, stagger: 0.1, duration: 0.65, ease: 'power2.out',
    scrollTrigger: { trigger: '#contacto', start: 'top 72%' },
  });

  gsap.from('.contact-form > *', {
    y: 20, opacity: 0, stagger: 0.1, duration: 0.65, ease: 'power2.out', delay: 0.15,
    scrollTrigger: { trigger: '#contacto', start: 'top 72%' },
  });
</script>
