---
const stats = [
  { number: 76,  label: 'Proyectos' },
  { number: 41,  label: 'Clientes'  },
  { number: 12,  label: 'Países'    },
  { number: 8,   label: 'Años'      },
];
---

<section id="nosotros" class="bg-brand-light py-32 md:py-40">
  <div class="max-w-6xl mx-auto px-8 md:px-14">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Text -->
      <div class="about-text">
        <p class="label-tag mb-5">Quiénes somos</p>
        <h2 class="font-heading text-brand-dark font-light leading-tight mb-8"
            style="font-size: clamp(1.8rem, 3.5vw, 3rem);">
          Creamos experiencias que conectan marcas con personas.
        </h2>
        <p class="text-brand-gray text-sm leading-relaxed mb-5 font-sans">
          Somos un equipo de diseñadores, estrategas y creativos apasionados por construir
          identidades de marca que perduran. Trabajamos con empresas que entienden que el
          diseño es una inversión, no un gasto.
        </p>
        <p class="text-brand-gray text-sm leading-relaxed mb-10 font-sans">
          Desde nuestra base en Santiago, hemos desarrollado proyectos para clientes en
          Latinoamérica, Europa y Estados Unidos — combinando perspectiva local con
          estándares internacionales.
        </p>
        <a href="#trabajos" class="btn-dark">Ver trabajos</a>
      </div>

      <!-- Stats grid -->
      <div class="about-stats grid grid-cols-2 gap-px bg-brand-dark/10">
        {stats.map((stat) => (
          <div class="stat-item bg-brand-light px-10 py-12 text-center">
            <div
              class="stat-num font-heading font-light text-brand-dark mb-2"
              style="font-size: clamp(2.5rem, 5vw, 4rem);"
              data-count={stat.number}
            >0</div>
            <div class="label-tag">{stat.label}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about-text > *', {
    y: 25, opacity: 0, stagger: 0.1, duration: 0.7, ease: 'power2.out',
    scrollTrigger: { trigger: '#nosotros', start: 'top 72%' },
  });

  document.querySelectorAll<HTMLElement>('.stat-item').forEach((item) => {
    const el = item.querySelector<HTMLElement>('[data-count]')!;
    const target = parseInt(el.dataset.count ?? '0');
    const obj = { value: 0 };

    gsap.to(obj, {
      value: target,
      duration: 1.6,
      ease: 'power2.out',
      onUpdate: () => { el.textContent = Math.round(obj.value).toString(); },
      scrollTrigger: { trigger: item, start: 'top 82%' },
    });
  });
</script>
