---
const year = new Date().getFullYear();
const socials = [
  { label: 'Instagram', href: '#' },
  { label: 'Behance',   href: '#' },
  { label: 'LinkedIn',  href: '#' },
];
---

<footer class="bg-brand-dark border-t border-white/5 py-14">
  <div class="max-w-6xl mx-auto px-8 md:px-14">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <a href="/" class="font-heading font-medium text-base tracking-[0.2em] text-white uppercase">
        clasi.co
      </a>

      <div class="flex items-center gap-8">
        {socials.map(s => (
          <a
            href={s.href}
            class="label-tag hover:text-white transition-colors duration-300"
          >{s.label}</a>
        ))}
      </div>

      <p class="font-accent text-brand-muted" style="font-size: 10px; letter-spacing: 0.1em;">
        &copy; {year} clasi.co &mdash; Todos los derechos reservados
      </p>

    </div>
  </div>
</footer>
