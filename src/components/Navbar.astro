---
const navLinks = [
  { label: 'Nosotros',  href: '#nosotros' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Trabajos',  href: '#trabajos' },
  { label: 'Clientes',  href: '#clientes' },
  { label: 'Contacto',  href: '#contacto' },
];
---

<!-- Top bar — mix-blend-difference makes white elements invert on light backgrounds -->
<header id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <div class="flex items-center justify-between px-8 md:px-14 py-7 mix-blend-difference">
    <a href="/" class="font-heading font-medium text-base tracking-[0.2em] text-white uppercase">
      clasi.co
    </a>
    <button
      id="burger-btn"
      class="flex flex-col gap-[5px] cursor-pointer"
      aria-label="Abrir menú"
    >
      <span class="burger-line block w-6 h-[1.5px] bg-white transition-all duration-300 origin-center"></span>
      <span class="burger-line block w-6 h-[1.5px] bg-white transition-all duration-300 origin-center"></span>
      <span class="burger-line block w-4 h-[1.5px] bg-white transition-all duration-300 origin-center"></span>
    </button>
  </div>
</header>

<!-- Full-screen overlay menu -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 bg-[#0a0a0a] flex flex-col justify-center px-10 md:px-20 opacity-0 pointer-events-none"
>
  <nav>
    <ul class="space-y-1">
      {navLinks.map((link, i) => (
        <li class="overflow-hidden">
          <a
            href={link.href}
            class="nav-link flex items-baseline gap-5 py-2 font-heading font-light text-white
                   hover:text-brand-muted transition-colors duration-300 translate-y-full opacity-0"
            style={`font-size: clamp(2.2rem, 5vw, 4.5rem);`}
          >
            <span class="font-accent text-brand-muted text-xs tracking-[0.3em]">0{i + 1}</span>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="absolute bottom-10 left-10 md:left-20 flex gap-8">
    <a href="mailto:hola@clasi.co" class="label-tag hover:text-white transition-colors duration-300">
      hola@clasi.co
    </a>
    <a href="https://instagram.com" class="label-tag hover:text-white transition-colors duration-300">
      Instagram
    </a>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const burgerBtn  = document.getElementById('burger-btn')!;
  const overlay    = document.getElementById('nav-overlay')!;
  const lines      = document.querySelectorAll<HTMLElement>('.burger-line');
  const navLinks   = document.querySelectorAll<HTMLElement>('.nav-link');
  let isOpen = false;

  function openMenu() {
    isOpen = true;
    // Burger → X
    gsap.to(lines[0], { rotation: 45,  y: 6.5,  duration: 0.35, ease: 'power2.inOut' });
    gsap.to(lines[1], { rotation: -45, y: 0,    duration: 0.35, ease: 'power2.inOut' });
    gsap.to(lines[2], { opacity: 0,              duration: 0.2 });

    // Reveal overlay
    gsap.to(overlay, { opacity: 1, pointerEvents: 'all', duration: 0.4, ease: 'power2.out' });
    gsap.to(navLinks, {
      translateY: 0,
      opacity: 1,
      stagger: 0.07,
      duration: 0.55,
      ease: 'power3.out',
      delay: 0.15,
    });
  }

  function closeMenu() {
    isOpen = false;
    // X → Burger
    gsap.to(lines[0], { rotation: 0, y: 0, duration: 0.35, ease: 'power2.inOut' });
    gsap.to(lines[1], { rotation: 0, y: 0, duration: 0.35, ease: 'power2.inOut' });
    gsap.to(lines[2], { opacity: 1, duration: 0.3, delay: 0.1 });

    // Hide overlay
    gsap.to(navLinks, {
      translateY: '100%',
      opacity: 0,
      stagger: 0.04,
      duration: 0.3,
      ease: 'power3.in',
    });
    gsap.to(overlay, { opacity: 0, pointerEvents: 'none', duration: 0.4, delay: 0.2 });
  }

  burgerBtn.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));
  navLinks.forEach(link => link.addEventListener('click', closeMenu));
</script>
